<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StepCounter" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#00B4FF</item>
        <item name="colorPrimaryDark">#060E18</item>
        <item name="colorAccent">#00B4FF</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="NeonDialogTheme" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="colorPrimary">#00B4FF</item>
        <item name="colorAccent">#00B4FF</item>
        <item name="android:background">#0D1B2A</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">#AAAAAA</item>
        <item name="buttonBarPositiveButtonStyle">@style/NeonButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/NeonButtonGhost</item>
    </style>

    <style name="NeonButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#00B4FF</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NeonButtonGhost" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#666666</item>
    </style>
</resources>