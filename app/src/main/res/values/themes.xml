<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StepCounter" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#4F46E5</item>
        <item name="colorPrimaryDark">#F7F8FF</item>
        <item name="colorAccent">#4F46E5</item>
        <item name="android:windowBackground">#F7F8FF</item>
        <item name="android:statusBarColor">#F7F8FF</item>
        <item name="android:navigationBarColor">#F7F8FF</item>
        <item name="android:textColorPrimary">#1E293B</item>
        <item name="android:textColorSecondary">#64748B</item>
    </style>

    <style name="NeonDialogTheme" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">#4F46E5</item>
        <item name="colorAccent">#4F46E5</item>
        <item name="android:textColorPrimary">#1E293B</item>
        <item name="android:textColorSecondary">#64748B</item>
        <item name="buttonBarPositiveButtonStyle">@style/NeonButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/NeonButtonGhost</item>
    </style>

    <style name="NeonButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#4F46E5</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="NeonButtonGhost" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#94A3B8</item>
    </style>
</resources>